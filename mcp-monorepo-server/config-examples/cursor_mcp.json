{
  "mcpServers": {
    "quantwarden-monorepo": {
      "command": "<ABSOLUTE_PATH_TO_REPO>/mcp-monorepo-server/.venv/bin/python",
      "args": [
        "<ABSOLUTE_PATH_TO_REPO>/mcp-monorepo-server/server.py"
      ],
      "env": {
        "ONEFORALL_API_URL": "http://127.0.0.1:8002",
        "SUBFINDER_API_URL": "http://127.0.0.1:8085",
        "PYSSL_API_URL": "http://127.0.0.1:8000",
        "NMAP_API_URL": "http://127.0.0.1:8010"
      }
    }
  }
}
